# Force LF line endings for all Python/text files (prevents CRLF issues on Kali)
* text=auto eol=lf

# Python files — always LF
*.py    text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.mako  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.db    binary
