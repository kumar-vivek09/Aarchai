# ── Database ─────────────────────────────────────────────────────────────
AARCHAI_DB_URL=postgresql://aarchai:aarchai@localhost:5432/aarchai

# ── Redis / Celery ────────────────────────────────────────────────────────
AARCHAI_REDIS_URL=redis://localhost:6379/0

# ── API keys (all optional, free tier) ───────────────────────────────────
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
NVD_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=stub
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Nuclei ───────────────────────────────────────────────────────────────
NUCLEI_MIN_SEVERITY=low
NUCLEI_TAGS=cve,misconfig,exposure,rce,sqli,xss,lfi,ssrf
NUCLEI_TEMPLATES_DIR=

# ── Alerts ───────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# ── Misc ─────────────────────────────────────────────────────────────────
TOOL_TIMEOUT=300
OUTPUT_DIR=./reports
